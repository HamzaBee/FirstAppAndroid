<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MultiApp Pro"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select an application to start"
        android:textSize="16sp"
        android:textColor="#757575"
        android:layout_marginBottom="40dp"/>

    <!-- App 1 Card/Button -->
    <Button
        android:id="@+id/btnApp1"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/title_app1"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@color/colorPrimary"
        app:backgroundTint="@color/colorPrimary"
        android:layout_margin="12dp"
        android:elevation="4dp"/>

    <!-- App 2 Card/Button -->
    <Button
        android:id="@+id/btnApp2"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/title_app2"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@color/colorPrimary"
        app:backgroundTint="@color/colorPrimary"
        android:layout_margin="12dp"
        android:elevation="4dp"/>

    <!-- App 3 Card/Button -->
    <Button
        android:id="@+id/btnApp3"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/title_app3"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@color/colorPrimary"
        app:backgroundTint="@color/colorPrimary"
        android:layout_margin="12dp"
        android:elevation="4dp"/>

</LinearLayout>